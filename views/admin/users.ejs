<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/public/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #212529;
            color: #f8f9fa;
        }
        .navbar-custom {
            background: #343a40;
        }
        .navbar-custom .navbar-brand,
        .navbar-custom .nav-link {
            color: #f8f9fa !important;
        }
        .card {
            background: #2c3034;
            border: 1px solid #495057;
        }
        .card-header {
            background: #2c3034;
            border-bottom: 1px solid #495057;
            color: #f8f9fa;
        }
        .card-header h5,
        .card-header h6 {
            color: #f8f9fa;
        }
        .form-control {
            background: #2c3034;
            border: 1px solid #495057;
            color: #f8f9fa;
        }
        .form-control:focus {
            background: #2c3034;
            border-color: #86b7fe;
            color: #f8f9fa;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }
        .form-label {
            color: #e9ecef;
        }
        .table {
            color: #f8f9fa;
            border-color: #495057;
        }
        .table > :not(caption) > * > * {
            background-color: transparent;
            color: #f8f9fa;
            border-color: #495057;
        }
        .table-hover tbody tr:hover {
            background: #3a3f44;
        }
        .modal-content {
            background: #2c3034;
            border: 1px solid #495057;
            color: #f8f9fa;
        }
        .modal-header {
            border-bottom: 1px solid #495057;
        }
        .modal-footer {
            border-top: 1px solid #495057;
        }
        .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }
        .text-muted {
            color: #adb5bd !important;
        }
        .btn-primary {
            background: #0d6efd;
            border: none;
        }
        .btn-primary:hover {
            background: #0b5ed7;
        }
        .btn-outline-light {
            border-color: #f8f9fa;
            color: #f8f9fa;
        }
        .btn-outline-light:hover {
            background: #f8f9fa;
            color: #212529;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid">
            <a class="navbar-brand" href="/admin/users">User Management</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/dashboard">Dashboard</a>
                    </li>
                    <% if (accountStorageType === 'file' || accountStorageType === 'single') { %>
                    <li class="nav-item">
                        <a class="nav-link active" href="/admin/users">Users</a>
                    </li>
                    <% } else if (accountStorageType === 'db') { %>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/sql-management">Teams & Logins</a>
                    </li>
                    <% } %>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/servers">Servers</a>
                    </li>
                </ul>
                <span class="navbar-text me-3 text-white">Welcome, <%= adminUsername %></span>
                <form method="POST" action="/admin/logout" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Users</h5>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#userModal" onclick="prepareAddUser()">Add New User</button>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <input type="text" class="form-control" id="loginIdFilter" placeholder="Filter by LoginID..." onkeyup="filterUsers()">
                </div>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>LoginID</th>
                                <th>TeamID</th>
                                <th>AccessCode</th>
                                <th>Permissions</th>
                                <th>Is Admin</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="usersBody">
                            <tr><td colspan="6" class="text-center">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="userModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Add New User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form id="userForm">
                    <div class="modal-body">
                        <input type="hidden" id="editLoginId" name="editLoginId">
                        <div class="mb-3">
                            <label for="loginId" class="form-label">LoginID</label>
                            <input type="text" class="form-control" id="loginId" name="loginId" required>
                        </div>
                        <div class="mb-3">
                            <label for="sid" class="form-label">TeamID</label>
                            <input type="number" class="form-control" id="sid" name="sid" required>
                        </div>
                        <div class="mb-3">
                            <label for="accessCode" class="form-label">AccessCode</label>
                            <input type="text" class="form-control" id="accessCode" name="accessCode" placeholder="Leave empty to auto-generate">
                            <small class="text-muted">AccessCode will be generated automatically when user is created if left empty</small>
                        </div>
                        <div class="mb-3">
                            <label for="prm" class="form-label">Permissions (hex)</label>
                            <input type="text" class="form-control" id="prm" name="prm" value="0xffffffff" required>
                        </div>
                        <div class="mb-3 form-check">
                            <input type="checkbox" class="form-check-input" id="isadmin" name="isadmin">
                            <label class="form-check-label" for="isadmin">Is Admin</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="/public/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        let users = {};
        let userModal;

        document.addEventListener('DOMContentLoaded', function() {
            userModal = new bootstrap.Modal(document.getElementById('userModal'));
            loadUsers();
        });

        async function loadUsers() {
            try {
                const response = await fetch('/admin/api/users');
                const data = await response.json();
                users = data.users || {};
                renderUsers();
            } catch (error) {
                console.error('Error loading users:', error);
                document.getElementById('usersBody').innerHTML = '<tr><td colspan="6" class="text-center text-danger">Error loading users</td></tr>';
            }
        }

        function renderUsers() {
            const tbody = document.getElementById('usersBody');
            const filterText = document.getElementById('loginIdFilter').value.toLowerCase();

            let filteredUsers = Object.entries(users);

            // Apply LoginID filter
            if (filterText) {
                filteredUsers = filteredUsers.filter(([loginID, user]) =>
                    loginID.toLowerCase().includes(filterText)
                );
            }

            if (filteredUsers.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center">No users found</td></tr>';
                return;
            }

            // Sort by SID (TeamID)
            filteredUsers.sort((a, b) => a[1].sid - b[1].sid);

            tbody.innerHTML = filteredUsers.map(([loginID, user]) => `
                <tr>
                    <td>${loginID}</td>
                    <td>${user.sid}</td>
                    <td>${user.AccessCode || user.pwd || 'N/A'}</td>
                    <td>${user.prm}</td>
                    <td>${user.isadmin ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-secondary">No</span>'}</td>
                    <td>
                        <button class="btn btn-sm btn-primary me-1" onclick="editUser('${loginID}')">Edit</button>
                        <button class="btn btn-sm btn-danger" onclick="deleteUser('${loginID}')">Delete</button>
                    </td>
                </tr>
            `).join('');
        }

        function filterUsers() {
            renderUsers();
        }

        function prepareAddUser() {
            const form = document.getElementById('userForm');
            const title = document.getElementById('modalTitle');
            form.reset();
            document.getElementById('editLoginId').value = '';
            document.getElementById('loginId').disabled = false;
            document.getElementById('accessCode').value = '';
            title.textContent = 'Add New User';
        }

        function editUser(loginID) {
            const form = document.getElementById('userForm');
            const title = document.getElementById('modalTitle');

            form.reset();
            document.getElementById('editLoginId').value = loginID;
            document.getElementById('loginId').value = loginID;
            document.getElementById('sid').value = users[loginID].sid;
            document.getElementById('accessCode').value = users[loginID].AccessCode || '';
            document.getElementById('prm').value = users[loginID].prm;
            document.getElementById('isadmin').checked = users[loginID].isadmin;
            document.getElementById('loginId').disabled = true;
            title.textContent = 'Edit User';

            userModal.show();
        }

        async function deleteUser(loginID) {
            if (!confirm(`Are you sure you want to delete user ${loginID}?`)) {
                return;
            }

            try {
                const response = await fetch(`/admin/api/users/${encodeURIComponent(loginID)}`, {
                    method: 'DELETE'
                });
                const data = await response.json();

                if (data.error === 0) {
                    delete users[loginID];
                    renderUsers();
                } else {
                    alert('Error deleting user: ' + (data.errorMessage || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error deleting user:', error);
                alert('Error deleting user');
            }
        }

        document.getElementById('userForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(e.target);
            const accessCode = formData.get('accessCode').trim() || null;
            const userData = {
                sid: parseInt(formData.get('sid')),
                prm: formData.get('prm'),
                isadmin: document.getElementById('isadmin').checked,
                accessCode: accessCode
            };

            const editLoginId = formData.get('editLoginId');
            const loginId = formData.get('loginId');
            const method = editLoginId ? 'PUT' : 'POST';
            const url = editLoginId ? `/admin/api/users/${encodeURIComponent(editLoginId)}` : '/admin/api/users';

            try {
                const response = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ email: loginId, ...userData })
                });
                const data = await response.json();

                if (data.error === 0) {
                    if (data.AccessCode) {
                        alert(`User created successfully! AccessCode: ${data.AccessCode}`);
                    }
                    userModal.hide();
                    loadUsers();
                } else {
                    alert('Error saving user: ' + (data.errorMessage || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error saving user:', error);
                alert('Error saving user');
            }
        });
    </script>
</body>
</html>
