<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="/public/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background: #212529;
            color: #f8f9fa;
        }
        .navbar-custom {
            background: #343a40;
        }
        .navbar-custom .navbar-brand,
        .navbar-custom .nav-link {
            color: #f8f9fa !important;
        }
        .card {
            background: #2c3034;
            border: 1px solid #495057;
        }
        .card-header {
            background: #2c3034;
            border-bottom: 1px solid #495057;
            color: #f8f9fa;
        }
        .card-header h5,
        .card-header h6 {
            color: #f8f9fa;
        }
        .form-control {
            background: #2c3034;
            border: 1px solid #495057;
            color: #f8f9fa;
        }
        .form-control:focus {
            background: #2c3034;
            border-color: #86b7fe;
            color: #f8f9fa;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
        }
        .form-select {
            background: #2c3034;
            border: 1px solid #495057;
            color: #f8f9fa;
        }
        .form-label {
            color: #e9ecef;
        }
        .team-card {
            border-left: 4px solid #0d6efd;
            background: #2c3034;
        }
        .login-card {
            border-left: 4px solid #6f42c1;
            margin-left: 20px;
            background: #2c3034;
        }
        .card-title {
            color: #e9ecef;
        }
        .card-subtitle {
            color: #adb5bd;
        }
        .card-text {
            color: #adb5bd;
        }
        .modal-content {
            background: #2c3034;
            border: 1px solid #495057;
            color: #f8f9fa;
        }
        .modal-header {
            border-bottom: 1px solid #495057;
        }
        .modal-footer {
            border-top: 1px solid #495057;
        }
        .btn-close {
            filter: invert(1) grayscale(100%) brightness(200%);
        }
        .text-muted {
            color: #adb5bd !important;
        }
        .btn-primary {
            background: #0d6efd;
            border: none;
        }
        .btn-primary:hover {
            background: #0b5ed7;
        }
        .btn-outline-primary {
            border-color: #0d6efd;
            color: #0d6efd;
        }
        .btn-outline-primary:hover {
            background: #0d6efd;
            color: #ffffff;
        }
        .btn-outline-light {
            border-color: #f8f9fa;
            color: #f8f9fa;
        }
        .btn-outline-light:hover {
            background: #f8f9fa;
            color: #212529;
        }
        .bg-primary {
            background: #0d6efd !important;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom">
        <div class="container-fluid">
            <a class="navbar-brand" href="/admin/dashboard">Admin Dashboard</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/users">Users (File)</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" href="/admin/sql-management">Teams & Logins (SQL)</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/servers">Servers</a>
                    </li>
                </ul>
                <span class="navbar-text me-3 text-white">Welcome, <%= adminUsername %></span>
                <form method="POST" action="/admin/logout" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="row mb-4">
            <div class="col-12">
                <h2>Teams & Logins Management (SQL)</h2>
                <p class="text-muted">Manage teams and their associated logins in SQLite database</p>
            </div>
        </div>

        <!-- Create Team Form -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">Create New Team</h5>
                    </div>
                    <div class="card-body">
                        <form id="createTeamForm">
                            <div class="row">
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label for="teamName" class="form-label">Team Name</label>
                                        <input type="text" class="form-control" id="teamName" required>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="mb-3">
                                        <label for="teamEmail" class="form-label">Email</label>
                                        <input type="email" class="form-control" id="teamEmail" required>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="mb-3">
                                        <label for="instanceLimit" class="form-label">Instance Limit</label>
                                        <input type="number" class="form-control" id="instanceLimit" value="999" required>
                                    </div>
                                </div>
                                <div class="col-md-2">
                                    <div class="mb-3">
                                        <label for="teamEnabled" class="form-label">Enabled</label>
                                        <select class="form-select" id="teamEnabled">
                                            <option value="1">Yes</option>
                                            <option value="0">No</option>
                                        </select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary">Create Team</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Teams List -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Teams</h5>
                        <button class="btn btn-sm btn-outline-primary" onclick="loadTeams()">Refresh</button>
                    </div>
                    <div class="card-body" id="teamsContainer">
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Create Login Modal -->
    <div class="modal fade" id="createLoginModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Create New Login</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="createLoginForm">
                        <input type="hidden" id="loginTeamId">
                        <div class="mb-3">
                            <label for="loginName" class="form-label">Login ID</label>
                            <input type="email" class="form-control" id="loginName" required>
                        </div>
                        <div class="mb-3">
                            <label for="accessCode" class="form-label">Access Code (optional - auto-generated if empty)</label>
                            <input type="text" class="form-control" id="accessCode" placeholder="Leave empty to auto-generate">
                        </div>
                        <div class="mb-3">
                            <label for="permissions" class="form-label">Permissions (Hex)</label>
                            <input type="text" class="form-control" id="permissions" value="0xffffffff" required>
                            <small class="text-muted">e.g., 0xffffffff for full permissions</small>
                        </div>
                        <div class="mb-3">
                            <label for="isAdmin" class="form-label">Is Admin</label>
                            <select class="form-select" id="isAdmin">
                                <option value="0">No</option>
                                <option value="1">Yes</option>
                            </select>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" onclick="submitCreateLogin()">Create Login</button>
                </div>
            </div>
        </div>
    </div>

    <script src="/public/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        let teamsData = [];

        function loadTeams() {
            document.getElementById('teamsContainer').innerHTML = `
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            `;

            fetch('/admin/api/sql/teams')
                .then(response => response.json())
                .then(data => {
                    teamsData = data.teams || [];
                    renderTeams();
                })
                .catch(error => {
                    console.error('Error loading teams:', error);
                    document.getElementById('teamsContainer').innerHTML = `
                        <div class="alert alert-danger">
                            Error loading teams: ${error.message}
                        </div>
                    `;
                });
        }

        function renderTeams() {
            if (teamsData.length === 0) {
                document.getElementById('teamsContainer').innerHTML = `
                    <div class="alert alert-info">
                        No teams found. Create a team to get started.
                    </div>
                `;
                return;
            }

            let html = '';
            teamsData.forEach(team => {
                html += `
                    <div class="card team-card mb-3">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="card-title">${team.TeamName}</h6>
                                    <p class="card-text mb-1">
                                        <small class="text-muted">Email: ${team.Email || 'N/A'}</small><br>
                                        <small class="text-muted">Team ID: ${team.TeamID}</small><br>
                                        <small class="text-muted">Instance Limit: ${team.InstanceLimit}</small><br>
                                        <small class="text-muted">Enabled: ${team.Enabled ? 'Yes' : 'No'}</small>
                                    </p>
                                </div>
                                <div>
                                    <button class="btn btn-sm btn-primary me-2" onclick="openCreateLoginModal(${team.TeamID}, '${team.TeamName}')">
                                        + Add Login
                                    </button>
                                    <button class="btn btn-sm btn-danger" onclick="deleteTeam(${team.TeamID})">
                                        Delete
                                    </button>
                                </div>
                            </div>
                            <div class="mt-3">
                                <h6 class="card-subtitle mb-2 text-muted">Logins (${team.logins ? team.logins.length : 0})</h6>
                                ${renderLogins(team.logins || [], team.TeamID)}
                            </div>
                        </div>
                    </div>
                `;
            });

            document.getElementById('teamsContainer').innerHTML = html;
        }

        function renderLogins(logins, teamId) {
            if (!logins || logins.length === 0) {
                return '<p class="text-muted mb-0">No logins for this team</p>';
            }

            let html = '<div class="row">';
            logins.forEach(login => {
                html += `
                    <div class="col-md-6 mb-2">
                        <div class="card login-card">
                            <div class="card-body py-2">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <small><strong>${login.LoginName}</strong></small><br>
                                        <small class="text-muted">AccessCode: ${login.AccessCode}</small><br>
                                        <small class="text-muted">Permissions: ${login.Permissions}</small>
                                        ${login.IsAdmin ? '<span class="badge bg-danger ms-1">Admin</span>' : ''}
                                    </div>
                                    <button class="btn btn-sm btn-outline-danger" onclick="deleteLogin(${login.LoginID}, ${teamId})">
                                        Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
            });
            html += '</div>';
            return html;
        }

        function openCreateLoginModal(teamId, teamName) {
            document.getElementById('loginTeamId').value = teamId;
            document.getElementById('loginName').value = teamName;
            document.getElementById('accessCode').value = '';
            document.getElementById('permissions').value = '0xffffffff';
            document.getElementById('isAdmin').value = '0';

            const modal = new bootstrap.Modal(document.getElementById('createLoginModal'));
            modal.show();
        }

        function submitCreateLogin() {
            const teamId = document.getElementById('loginTeamId').value;
            const loginName = document.getElementById('loginName').value;
            const accessCode = document.getElementById('accessCode').value.trim();
            const permissions = document.getElementById('permissions').value;
            const isAdmin = document.getElementById('isAdmin').value;

            fetch('/admin/api/sql/logins', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    teamId: teamId,
                    loginName: loginName,
                    accessCode: accessCode || null, // Send null if empty to trigger auto-generation
                    permissions: permissions,
                    isAdmin: isAdmin
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert('Error creating login: ' + data.error);
                } else {
                    const modal = bootstrap.Modal.getInstance(document.getElementById('createLoginModal'));
                    modal.hide();
                    loadTeams();
                }
            })
            .catch(error => {
                console.error('Error creating login:', error);
                alert('Error creating login: ' + error.message);
            });
        }

        function deleteTeam(teamId) {
            if (!confirm('Are you sure you want to delete this team and all its logins?')) {
                return;
            }

            fetch(`/admin/api/sql/teams/${teamId}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert('Error deleting team: ' + data.error);
                } else {
                    loadTeams();
                }
            })
            .catch(error => {
                console.error('Error deleting team:', error);
                alert('Error deleting team: ' + error.message);
            });
        }

        function deleteLogin(loginId, teamId) {
            if (!confirm('Are you sure you want to delete this login?')) {
                return;
            }

            fetch(`/admin/api/sql/logins/${loginId}`, {
                method: 'DELETE'
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert('Error deleting login: ' + data.error);
                } else {
                    loadTeams();
                }
            })
            .catch(error => {
                console.error('Error deleting login:', error);
                alert('Error deleting login: ' + error.message);
            });
        }

        document.getElementById('createTeamForm').addEventListener('submit', function(e) {
            e.preventDefault();

            const teamName = document.getElementById('teamName').value;
            const teamEmail = document.getElementById('teamEmail').value;
            const instanceLimit = document.getElementById('instanceLimit').value;
            const enabled = document.getElementById('teamEnabled').value;

            fetch('/admin/api/sql/teams', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    teamName: teamName,
                    email: teamEmail,
                    instanceLimit: instanceLimit,
                    enabled: enabled
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.error) {
                    alert('Error creating team: ' + data.error);
                } else {
                    document.getElementById('createTeamForm').reset();
                    document.getElementById('instanceLimit').value = '999';
                    document.getElementById('teamEnabled').value = '1';
                    loadTeams();
                }
            })
            .catch(error => {
                console.error('Error creating team:', error);
                alert('Error creating team: ' + error.message);
            });
        });

        // Load teams on page load
        loadTeams();
    </script>
</body>
</html>
